<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
	<TargetFrameworks>$(DefaultNetTargetFramework)</TargetFrameworks>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <AllowUnsafeBlocks>True</AllowUnsafeBlocks>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.Extensions.ObjectPool" />
    <PackageReference Include="Polly.Core" />
    <PackageReference Include="ZstdSharp.Port" />
	<PackageReference Include="System.IO.Pipelines" />
	<PackageReference Include="System.IO.Hashing" />
	<PackageReference Include="Microsoft.Extensions.Logging.Abstractions" />
  </ItemGroup>

	<ItemGroup>
		<None Include="runtimes\**\native\*" Pack="true" PackagePath="runtimes\%(RecursiveDir)native\" />
	</ItemGroup>

	<!-- Local testing -->
	<ItemGroup Condition="$([MSBuild]::IsOSPlatform('Windows'))">
		<Content Include="runtimes\win-x64\native\mimalloc.dll" Link="mimalloc.dll" CopyToOutputDirectory="PreserveNewest" />
		<Content Include="runtimes\win-x64\native\mimalloc-redirect.dll" Link="mimalloc-redirect.dll" CopyToOutputDirectory="PreserveNewest" />
	</ItemGroup>

	<ItemGroup Condition="$([MSBuild]::IsOSPlatform('Linux'))">
		<Content Include="runtimes\linux-x64\native\libmimalloc.so" Link="libmimalloc.so" CopyToOutputDirectory="PreserveNewest" />
	</ItemGroup>

	<ItemGroup Condition="$([MSBuild]::IsOSPlatform('OSX'))">
		<Content Include="runtimes\osx-arm64\native\libmimalloc.dylib" Link="libmimalloc.dylib" CopyToOutputDirectory="PreserveNewest" />
	</ItemGroup>
</Project>
